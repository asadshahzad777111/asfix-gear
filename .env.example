# Copy to .env — never commit .env
NODE_ENV=production
PORT=5000

# Comma-separated allowed frontend origins (production CORS only)
# Set on Render dashboard after custom domain — see DOMAIN-SETUP.md
# https://asfixgear.com,https://www.asfixgear.com
CORS_ORIGIN=https://asfixgear.com,https://www.asfixgear.com

# ── Email OTP (Gmail signup / login verification) ──
# Required on Render for customer Gmail OTP to work.
# GMAIL_USER=asadshahzad777111@gmail.com
# GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
# SMTP_FROM="AsFix Gear" <asadshahzad777111@gmail.com>

# Option B: Custom SMTP
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM="AsFix Gear" <your@gmail.com>

# ── SMS OTP (Twilio) — primary for phone login ──
# TWILIO_ACCOUNT_SID=ACxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxx
# TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ── WhatsApp OTP fallback (if SMS fails or not configured) ──
# Twilio WhatsApp:
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# OR Meta WhatsApp Cloud API:
# WHATSAPP_TOKEN=your-graph-api-token
# WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id

# Shop WhatsApp for dev manual link fallback (default: 923039227000)
# SHOP_WHATSAPP_INTL=923039227000
